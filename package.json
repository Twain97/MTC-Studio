{
  "name": "mtc-studio-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n css,app -c cyan,yellow \"npm run dev:css\" \"node --watch src/server.js\"",
    "dev:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/app.css --watch",
    "start": "node server.js",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/app.css --minify",
    "check": "node --check src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}
