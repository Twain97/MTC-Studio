<%- include('../partials/head', { title, bodyClass: 'min-h-screen bg-dawn-50 text-dawn-950' }) %>
<%- include('../partials/site-header', { page }) %>
<main>
  <section class="page-hero">
    <div class="site-container relative z-10 py-24 text-center md:py-32">
      <p class="eyebrow text-gold-300">About MTC Studio</p>
      <h1 class="mt-4 font-display text-5xl font-semibold text-white md:text-7xl">The person behind the lens</h1>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-dawn-100">A photography studio built around honest observation, refined craft, and excellent client care.</p>
    </div>
  </section>
  <section class="about section-pad bg-white">
    <div class="site-container grid items-center gap-12 lg:grid-cols-2">
      <div data-reveal class="grid grid-cols-2 gap-4">
        <img src="/images/photographer.webp" alt="MTC Studio photographer at work" class="mt-14 h-[470px] w-full object-cover" loading="lazy" decoding="async" data-fallback-src="/images/vc_wedding.png" />
        <img src="/images/vc_wedding.png" alt="Wedding photography by MTC Studio" class="h-[470px] w-full object-cover" loading="lazy" decoding="async" data-fallback-src="/images/photographer.webp" />
      </div>
      <div data-reveal="100" class="lg:pl-10">
        <p class="eyebrow text-gold-700">Our perspective</p>
        <h2 class="section-title mt-4">Photographs should carry feeling, not just detail.</h2>
        <p class="mt-6 text-base leading-8 text-dawn-700">MTC Studio documents people at their most present. The work is grounded in an editorial sensibility, but the heart of every assignment is the unrepeatable human moment happening in front of the lens.</p>
        <p class="mt-4 text-base leading-8 text-dawn-700">Based in Lagos and available for selected travel, we work with couples, families, creative teams, and brands that care about images with lasting character.</p>
        <a href="/contact" class="btn-dark mt-8">Work with us</a>
      </div>
    </div>
  </section>
  <section class="section-pad bg-dawn-100">
    <div class="site-container grid gap-6 md:grid-cols-3">
      <% values.forEach((value, index) => { %>
        <article data-reveal="<%= index * 100 %>" class="bg-white p-8">
          <h2 class="mt-7 font-display text-3xl"><%= value.title %></h2>
          <p class="mt-4 text-sm leading-7 text-dawn-600"><%= value.text %></p>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/site-footer') %>
<%- include('../partials/whatsapp', { whatsappNumber }) %>
<%- include('../partials/site-scripts') %>
