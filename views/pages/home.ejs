<%- include('../partials/head', { title, bodyClass: 'min-h-screen bg-dawn-50 text-dawn-950' }) %>
<%- include('../partials/site-header', { page }) %>
<% if (constructionOverlayEnabled) { %>
  <div class="construction-overlay" role="status" aria-live="polite">
    <div class="construction-overlay-panel">
      <div class="construction-overlay-icons" aria-hidden="true">
        <svg class="construction-spanner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a4.6 4.6 0 0 0-5.5 5.5L3.7 17.3a2.1 2.1 0 0 0 3 3l5.5-5.5a4.6 4.6 0 0 0 5.5-5.5l-3 3-3-3 3-3Z" />
        </svg>
        <svg class="construction-cog" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 8.2a3.8 3.8 0 1 0 0 7.6 3.8 3.8 0 0 0 0-7.6Z" />
          <path d="m19.4 15.2-.9 1.5 1 2.2-2.2 2.2-2.2-1-1.6.7-.8 2.2H10l-.8-2.2-1.6-.7-2.2 1-2.2-2.2 1-2.2-.8-1.5L1.2 14v-3l2.2-.8.8-1.5-1-2.2 2.2-2.2 2.2 1 1.6-.7L10 2.4h3l.8 2.2 1.6.7 2.2-1 2.2 2.2-1 2.2.8 1.5 2.2.8v3l-2.4 1.2Z" />
        </svg>
      </div>
      <p class="eyebrow text-gold-300">MTC Studio</p>
      <h2>Website Construction in Progress</h2>
      <p>We are updating the website. Please check back soon.</p>
    </div>
  </div>
<% } %>
<main>
  <section class="hero">
    <div class="grid min-h-[calc(100vh-5rem)] bg-dawn-700 lg:grid-cols-[.9fr_1.1fr]">
      <div class="relative min-h-[620px] overflow-hidden">
        <img src="/images/vc_wedding.png" alt="Bride photographed by MTC Studio" class="absolute inset-0 h-full w-full object-cover object-center" decoding="async" fetchpriority="high" data-fallback-src="/images/photographer.webp" />
        <div class="absolute inset-0 bg-gradient-to-r from-dawn-950/30 via-transparent to-dawn-950/10"></div>
        <div class="mx-auto mt-80 max-w-xs rounded-lg border border-white/30 bg-dawn-950/75 p-5 text-white backdrop-blur md:absolute md:bottom-12 md:right-12">
          <p class="font-display text-2xl">MTC Studio</p>
          <p class="mt-2 text-xs uppercase tracking-[.2em] text-gold-200">Photography with intention</p>
        </div>
      </div>
      <div class="hero-panel flex items-center">
        <div class="relative z-10 px-6 py-10 sm:px-12 lg:ml-auto lg:max-w-2xl lg:px-16">
          <p class="eyebrow text-dawn-950">Lagos · Available Nationwide</p>
          <h1 class="mt-6 font-display text-6xl font-semibold leading-[.88] text-dawn-950 sm:text-7xl xl:text-8xl">Stories in<br /><em class="font-normal">every frame.</em></h1>
          <p class="mt-7 max-w-lg text-base leading-8 text-dawn-900">Refined photography for weddings, portraits, and brands. We capture the movement and meaning inside each moment and turn them into lasting memories.</p>
          <div class="mt-9 flex flex-wrap gap-4">
            <a href="/portfolio" class="btn-dark rounded-md">View portfolio</a>
            <a href="/contact" class="btn-outline-dark rounded-md">Book a session</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about section-pad overflow-hidden bg-dawn-900">
    <div class="site-container grid items-center gap-12 lg:grid-cols-2">
      <div data-reveal class="relative">
        <img src="/images/photographer.webp" alt="MTC Studio photographer holding a camera" class="h-[540px] w-full rounded-md object-cover" loading="lazy" decoding="async" data-fallback-src="/images/vc_wedding.png" />
        <div class="absolute -bottom-7 -right-3 hidden w-52 rounded-md bg-gold-300 p-6 text-dawn-950 sm:block">
          <p class="font-display text-4xl font-semibold">5+</p>
          <p class="mt-1 text-xs font-bold uppercase tracking-[.16em]">Years creating memories</p>
        </div>
      </div>
      <div data-reveal="120" class="lg:pl-10">
        <p class="eyebrow text-gold-700">MTC Studio</p>
        <h2 class="section-title mt-4">Images that feel like the moment.</h2>
        <p class="mt-6 text-base leading-8 text-dawn-200"><span class="section-title font-bold text-gold-700">H</span>ello. I am <span class="section-title font-bold text-gold-700">T</span>aiwo, the face and chief memory preserver behind MTC Studio. With over five years behind the lens, we have documented weddings, birthdays, convocations, and milestone events with the aim of making the memory feel alive every time it is revisited.</p>
        <p class="mt-4 text-base leading-8 text-dawn-200">The result is a body of photographs and films that stay emotionally clear long after the day itself has passed.</p>
        <a href="/about" class="mt-8 inline-flex items-center gap-2 text-sm font-bold uppercase tracking-[.18em] text-dawn-100">Meet MTC Studio</a>
      </div>
    </div>
  </section>

  <section class="services section-pad bg-dawn-950 text-white">
    <div class="site-container">
      <div data-reveal class="max-w-2xl">
        <p class="eyebrow text-gold-300">What we photograph</p>
        <h2 class="section-title mt-4 text-white">Considered coverage for every kind of story.</h2>
      </div>
      <div class="mt-12 grid gap-px bg-white/10 md:grid-cols-3">
        <% services.forEach((service, index) => { %>
          <article data-reveal="<%= index * 100 %>" class="bg-dawn-950 p-8 transition hover:bg-dawn-900 md:p-10">
            <h3 class="mt-8 font-display text-3xl"><%= service.title %></h3>
            <p class="mt-4 text-sm leading-7 text-dawn-200"><%= service.text %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="portfolio section-pad bg-dawn-100">
    <div class="site-container">
      <div data-reveal class="flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
        <div>
          <p class="eyebrow rounded-md bg-dawn-200 px-4 py-2 text-gold-700">Contracts Done</p>
          <h2 class="section-title mt-4">Recent Contracts</h2>
        </div>
      </div>
      <div class="mt-12 grid gap-7 md:grid-cols-2">
        <% projects.forEach((project, index) => { %>
          <article data-reveal="<%= index * 80 %>" class="portfolio-card group rounded-md <%= index >= 3 ? 'hidden lg:block' : '' %>">
            <div class="relative overflow-hidden">
              <img src="<%= project.thumbnail %>" alt="<%= project.eventName %> photography in <%= project.location %> by MTC Studio" class="h-80 w-full object-cover transition duration-700 group-hover:scale-105 md:h-96" loading="lazy" decoding="async" data-fallback-src="/images/photographer.webp" />
              <div class="absolute inset-0 bg-gradient-to-t from-dawn-950/85 via-transparent to-transparent"></div>
              <a href="/portfolio/<%= project._id %>" class="event-button">View event</a>
            </div>
            <div class="p-5">
              <h2 class="font-display text-2xl font-semibold text-dawn-950"><%= project.eventName %></h2>
              <div class="mt-4 flex items-center justify-between gap-3 border-t border-dawn-200 pt-4 text-xs font-semibold uppercase tracking-[.12em] text-dawn-600">
                <span><%= new Intl.DateTimeFormat('en', { month: 'long', year: 'numeric' }).format(new Date(project.eventDate)) %></span>
                <span class="text-right"><%= project.location %></span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
      <div data-reveal class="mt-10 flex justify-center">
        <a href="/portfolio" class="btn-dark w-3/4 rounded-md">View All Jobs Done.</a>
      </div>
    </div>
  </section>

  <section class="pricing section-pad bg-white">
    <div class="site-container">
      <div data-reveal class="mx-auto max-w-2xl text-center">
        <p class="eyebrow rounded-md bg-dawn-200 px-4 py-2 text-gold-700">Starting investment</p>
        <h2 class="section-title mt-4">Choose the right experience.</h2>
        <p class="mt-5 text-dawn-600">Each collection can be tailored to your date, location, and creative needs.</p>
      </div>
      <div class="mt-12 grid items-stretch gap-6 lg:grid-cols-3">
        <% pricing.forEach((plan, index) => { %>
          <article data-reveal="<%= index * 100 %>" class="relative border p-8 <%= plan.featured ? 'rounded-lg border-gold-400 bg-dawn-950 text-white shadow-glow lg:-translate-y-4' : 'border-dawn-200 bg-dawn-50' %>">
            <% if (plan.featured) { %><span class="absolute right-5 top-5 rounded-lg bg-gold-300 px-3 py-1 text-[10px] font-bold uppercase tracking-[.16em] text-dawn-950">Most popular</span><% } %>
            <h3 class="font-display text-3xl"><%= plan.name %></h3>
            <p class="mt-4 text-4xl font-semibold text-gold-400"><%= plan.price %></p>
            <p class="mt-4 text-sm leading-7 <%= plan.featured ? 'text-dawn-200' : 'text-dawn-600' %>"><%= plan.detail %></p>
            <ul class="mt-7 grid gap-3 text-sm">
              <% plan.features.forEach((feature) => { %><li><%= feature %></li><% }) %>
            </ul>
            <a href="/contact" class="mt-8 inline-flex text-xs font-bold uppercase tracking-[.18em] text-gold-400">Request availability</a>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="contact section-pad bg-dawn-800 text-white">
    <div class="site-container grid gap-12 rounded-lg lg:grid-cols-[.8fr_1.2fr]">
      <div data-reveal>
        <p class="eyebrow text-gold-300">Start a conversation</p>
        <h2 class="section-title mt-4 text-white">Tell us what you are planning.</h2>
        <p class="mt-6 max-w-md text-base leading-8 text-dawn-100">Share your date, location, and the feeling you want your photographs to hold. We normally reply within one business day.</p>
      </div>
      <div data-reveal="120" class="rounded-lg bg-white p-6 text-dawn-950 shadow-glow sm:p-9">
        <%- include('../partials/contact-form') %>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/site-footer') %>
<%- include('../partials/whatsapp', { whatsappNumber }) %>
<%- include('../partials/site-scripts') %>
