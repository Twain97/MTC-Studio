<%- include('../partials/head', { title, bodyClass: 'min-h-screen bg-dawn-50 text-dawn-950' }) %>
<%- include('../partials/site-header', { page }) %>
<main>
  <section class="relative min-h-[72vh] overflow-hidden bg-dawn-950">
    <img src="<%= project.thumbnail %>" alt="<%= project.eventName %>" class="absolute inset-0 h-full w-full object-cover opacity-75" />
    <div class="absolute inset-0 bg-gradient-to-t from-dawn-950 via-dawn-950/30 to-transparent"></div>
    <div class="site-container relative z-10 flex min-h-[72vh] items-end pb-16 text-white">
      <div>
        <a href="/portfolio" class="mb-8 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[.18em]">Portfolio</a>
        <h1 class="font-display text-5xl font-semibold md:text-7xl"><%= project.eventName %></h1>
        <div class="mt-5 flex flex-wrap gap-6 text-xs font-semibold uppercase tracking-[.15em] text-gold-200">
          <span><%= new Intl.DateTimeFormat('en', { month: 'long', year: 'numeric' }).format(new Date(project.eventDate)) %></span>
          <span><%= project.location %></span>
        </div>
      </div>
    </div>
  </section>
  <section class="section-pad bg-white">
    <div class="site-container">
      <% if (project.description) { %><p data-reveal class="mx-auto max-w-3xl text-center font-display text-3xl leading-snug text-dawn-800 md:text-4xl"><%= project.description %></p><% } %>
      <div class="mt-14 grid gap-5 md:grid-cols-2">
        <% project.images.forEach((image, index) => { %>
          <img data-reveal="<%= index * 70 %>" src="<%= image %>" alt="<%= project.eventName %> photograph <%= index + 1 %>" class="h-[480px] w-full object-cover <%= index === 0 && project.images.length % 2 ? 'md:col-span-2 md:h-[650px]' : '' %>" />
        <% }) %>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/site-footer') %>
<%- include('../partials/whatsapp', { whatsappNumber }) %>
<%- include('../partials/site-scripts') %>
