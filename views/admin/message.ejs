<%- include('../partials/admin-head', { title }) %>
<%- include('../partials/admin-shell-start', { page }) %>
<div data-message-page data-message-id="<%= messageId %>">
  <div class="flex items-center justify-between gap-4">
    <div>
      <p class="eyebrow text-gold-700">Client communication</p>
      <h1 class="mt-2 font-display text-4xl font-semibold">Message detail</h1>
    </div>
    <a href="/admin/messages" class="text-xs font-bold uppercase tracking-[.14em] text-dawn-700">Back to inbox</a>
  </div>

  <p class="mt-10 text-dawn-500" data-message-loading>Loading message...</p>
  <section class="mt-8 hidden border border-dawn-200 bg-white" data-message-shell>
    <div class="border-b border-dawn-200 p-6 sm:p-8">
      <div class="flex flex-col justify-between gap-4 sm:flex-row">
        <div>
          <p class="text-xs font-bold uppercase tracking-[.14em] text-gold-700" data-message-status></p>
          <h2 class="mt-2 font-display text-3xl" data-message-subject></h2>
          <p class="mt-2 text-sm text-dawn-500" data-message-meta></p>
        </div>
        <time class="text-xs text-dawn-400" data-message-date></time>
      </div>
      <div class="mt-7 whitespace-pre-wrap bg-dawn-50 p-6 text-sm leading-7 text-dawn-800" data-message-body></div>
    </div>

    <div class="border-b border-dawn-200 bg-dawn-50 p-6 sm:p-8" data-message-replies></div>

    <form class="p-6 sm:p-8" data-reply-form>
      <label class="form-label">Reply to this client
        <textarea name="body" class="form-input resize-none" rows="6" required placeholder="Write your response..."></textarea>
      </label>
      <div class="mt-4 flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
        <label class="inline-flex cursor-pointer items-center gap-2 text-xs font-bold uppercase tracking-[.12em] text-dawn-600">
          Attach contract PDF
          <input type="file" name="contract" accept="application/pdf" class="sr-only" data-contract-input />
        </label>
        <span class="text-xs font-semibold text-dawn-500" data-contract-name>No file attached</span>
        <button class="btn-dark sm:ml-auto" type="submit" data-reply-submit>
          <span data-reply-label>Send reply</span>
          <svg class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-reply-spinner>
            <circle cx="12" cy="12" r="9" opacity="0.25"></circle>
            <path d="M21 12a9 9 0 0 1-9 9"></path>
          </svg>
        </button>
      </div>
      <p class="mt-4 text-sm text-dawn-600" data-reply-notice></p>
    </form>
  </section>
</div>
<script src="/js/admin-message.js" defer></script>
<%- include('../partials/admin-shell-end') %>
<%- include('../partials/admin-foot') %>
