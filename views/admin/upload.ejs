<%- include('../partials/admin-head', { title }) %>
<%- include('../partials/admin-shell-start', { page }) %>
<div>
  <p class="eyebrow text-gold-700">Portfolio manager</p>
  <h1 class="mt-2 font-display text-4xl font-semibold">Upload an event</h1>
  <div class="mt-8 grid gap-8 xl:grid-cols-[1.15fr_.85fr]">
    <form class="border border-dawn-200 bg-white p-6 sm:p-8" data-upload-form>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="form-label sm:col-span-2">Event name<input name="eventName" class="form-input" required placeholder="e.g. Ada & Kelechi" /></label>
        <label class="form-label">Month and year<input name="eventDate" type="month" class="form-input" required /></label>
        <label class="form-label">Location<input name="location" class="form-input" required placeholder="Lagos, Nigeria" /></label>
        <label class="form-label sm:col-span-2">Event description<textarea name="description" class="form-input resize-none" rows="4" placeholder="A short introduction shown on the event page."></textarea></label>
      </div>

      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        <label class="upload-box">
          <strong>Choose thumbnail</strong>
          <span>JPG, PNG or WebP, up to 20MB</span>
          <input type="file" name="thumbnail" accept="image/jpeg,image/png,image/webp" class="sr-only" required data-thumbnail-input />
        </label>
        <img src="" alt="Thumbnail preview" class="hidden h-44 w-full object-cover" data-thumbnail-preview />
        <div class="grid h-44 place-items-center bg-dawn-100 text-xs uppercase tracking-[.14em] text-dawn-400" data-thumbnail-placeholder>Thumbnail preview</div>
      </div>

      <label class="upload-box mt-6">
        <strong>Choose up to 5 event images</strong>
        <span>These appear inside the event gallery</span>
        <input type="file" name="images" multiple accept="image/jpeg,image/png,image/webp" class="sr-only" data-images-input />
      </label>
      <div class="mt-4 hidden grid-cols-2 gap-3 sm:grid-cols-5" data-gallery-previews></div>

      <label class="mt-6 flex items-center gap-3 text-sm font-semibold"><input name="featured" type="checkbox" class="h-4 w-4 accent-gold-600" /> Feature this event on the home page</label>
      <p class="mt-5 hidden text-sm" data-upload-notice></p>
      <button class="btn-dark mt-7" type="submit" data-submit-label="Publish project">Publish project</button>
    </form>

    <aside>
      <div class="flex items-center justify-between">
        <h2 class="font-display text-3xl">Published projects</h2>
        <span class="rounded-full bg-dawn-200 px-3 py-1 text-xs font-semibold" data-project-count>0</span>
      </div>
      <div class="mt-5 border border-dashed border-dawn-300 p-8 text-center text-sm text-dawn-500" data-projects-empty>No database projects yet.</div>
      <div class="mt-5 grid gap-4" data-projects-list></div>
    </aside>
  </div>
</div>
<script src="/js/admin-upload.js" defer></script>
<%- include('../partials/admin-shell-end') %>
<%- include('../partials/admin-foot') %>
