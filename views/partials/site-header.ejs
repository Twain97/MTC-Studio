<header class="site-header">
  <div class="site-container flex h-20 items-center justify-between gap-6">
    <a href="/" class="shrink-0">
      <span class="logo-crop" aria-label="MTC Studio">
        <img src="/images/mtc-studio.png" alt="MTC Studio" />
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      <a href="/" class="nav-link <%= page === 'home' ? 'is-active' : '' %>">Home</a>
      <a href="/about" class="nav-link <%= page === 'about' ? 'is-active' : '' %>">About</a>
      <a href="/portfolio" class="nav-link <%= page === 'portfolio' ? 'is-active' : '' %>">Portfolio</a>
      <a href="/contact" class="nav-link <%= page === 'contact' ? 'is-active' : '' %>">Contact</a>
      <a href="/contact" class="btn-gold rounded-md !px-5 !py-2.5">Book a session</a>
    </nav>

    <button class="rounded-full border border-white/20 p-2 text-white md:hidden" aria-label="Toggle menu" data-mobile-nav-toggle>
      <svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <nav class="hidden border-t border-white/10 bg-dawn-950 px-5 py-5 md:hidden" aria-label="Mobile navigation" data-mobile-nav>
    <a href="/" class="block border-b border-white/10 py-3 text-sm font-semibold uppercase tracking-[.18em] text-white">Home</a>
    <a href="/about" class="block border-b border-white/10 py-3 text-sm font-semibold uppercase tracking-[.18em] text-white">About</a>
    <a href="/portfolio" class="block border-b border-white/10 py-3 text-sm font-semibold uppercase tracking-[.18em] text-white">Portfolio</a>
    <a href="/contact" class="block py-3 text-sm font-semibold uppercase tracking-[.18em] text-white">Contact</a>
  </nav>
</header>
